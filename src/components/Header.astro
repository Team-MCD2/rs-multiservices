---
const { city = "toulouse" } = Astro.params;
const cityPrefix = city ? `/${city}` : "/toulouse";
---

<header class="site-header">
  <div class="container nav">
    <a href={`${cityPrefix}/`} class="brand" aria-label="RS Multi-Services - Accueil">
      <img src="/logors.png" alt="Logo R&S Multi-Services" />
      <span class="brand-text">
        <strong>RS Multi-Services</strong>
        <span style="text-transform: capitalize;">{city || "Toulouse"} · 7j/7</span>
      </span>
    </a>
    <ul class="nav-menu" id="primary-nav">
      <li><a href={`${cityPrefix}/`}>Accueil</a></li>
      <li><a href={`${cityPrefix}/about`}>À propos</a></li>
      <li><a href={`${cityPrefix}/services`}>Services</a></li>
      <li><a href={`${cityPrefix}/realisations`}>Réalisations</a></li>
      <li><a href={`${cityPrefix}/contact`}>Contact</a></li>
    </ul>
    <div class="nav-actions">
      <a class="nav-tel" href="tel:+33619696812"><i class="fa-solid fa-phone"></i> 06 19 69 68 12</a>
      <button type="button" class="theme-toggle" aria-label="Basculer le thème clair/sombre" aria-pressed="false" data-theme-toggle>
        <i class="fa-solid fa-moon icon-moon" aria-hidden="true"></i>
        <i class="fa-solid fa-sun icon-sun" aria-hidden="true"></i>
      </button>
      <a href={`${cityPrefix}/contact`} class="btn btn-primary">Devis gratuit</a>
      <button class="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="primary-nav">
        <i class="fa-solid fa-bars"></i>
      </button>
    </div>
  </div>
</header>
