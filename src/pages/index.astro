---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="RS Multi-Services Toulouse — Bricolage, Jardinage, Nettoyage, Débarras 7j/7"
  description="RS Multi-Services à Toulouse et 50 km autour : petit bricolage, entretien d'espaces verts, nettoyage intérieur/extérieur, enlèvement d'encombrants. Devis gratuit, disponible 7j/7 de 8h à 19h. ☎ 06 19 69 68 12."
  canonical="https://rsmultiservices.fr/"
  hasHero={true}
>
  <Fragment slot="head">
    <style>
      /* 1) Le header flotte par-dessus le hero (pas dans le flux) */
      body.has-hero .site-header {
        position: fixed !important;
        top: 0; left: 0; right: 0;
        z-index: 100;
      }

      /* 2) État TRANSPARENT au top de la page */
      body.has-hero .site-header:not(.is-scrolled) {
        background: transparent !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        border-bottom: 1px solid transparent !important;
        box-shadow: none !important;
      }
      body.has-hero .site-header:not(.is-scrolled) .nav { background: transparent !important; }
      body.has-hero .site-header:not(.is-scrolled) .brand-text strong,
      body.has-hero .site-header:not(.is-scrolled) .nav-menu > li > a,
      body.has-hero .site-header:not(.is-scrolled) .nav-tel,
      body.has-hero .site-header:not(.is-scrolled) .nav-toggle { color:#fff !important; }
      body.has-hero .site-header:not(.is-scrolled) .brand-text span { color: rgba(255,255,255,0.85) !important; }
      body.has-hero .site-header:not(.is-scrolled) .brand img { filter: drop-shadow(0 2px 10px rgba(0,0,0,0.55)); }
    </style>

    <!-- JSON-LD : LocalBusiness -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "HomeAndConstructionBusiness",
      "name": "RS Multi-Services",
      "alternateName": "R&S Multi-Services",
      "description": "Bricolage, entretien d'espaces verts, nettoyage intérieur/extérieur et enlèvement d'encombrants à Toulouse et 50 km autour.",
      "image": "https://rsmultiservices.fr/assets/og-image.jpg",
      "url": "https://rsmultiservices.fr/",
      "telephone": "+33619696812",
      "email": "raymond.spire31@gmail.com",
      "priceRange": "€€",
      "founder": { "@type": "Person", "name": "Raymond Spire" },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Pechbonnieu",
        "postalCode": "31140",
        "addressRegion": "Occitanie",
        "addressCountry": "FR"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 43.7077, "longitude": 1.4628 },
      "areaServed": [
        { "@type": "City", "name": "Toulouse" },
        { "@type": "City", "name": "Pechbonnieu" },
        { "@type": "City", "name": "L'Union" },
        { "@type": "City", "name": "Saint-Loup-Cammas" },
        { "@type": "City", "name": "Castelmaurou" },
        { "@type": "City", "name": "Montberon" },
        { "@type": "City", "name": "Rouffiac-Tolosan" },
        { "@type": "City", "name": "Saint-Geniès-Bellevue" },
        { "@type": "City", "name": "Launaguet" },
        { "@type": "City", "name": "Aucamville" },
        { "@type": "City", "name": "Fenouillet" },
        { "@type": "City", "name": "Castelginest" },
        { "@type": "City", "name": "Bruguières" }
      ],
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "08:00",
        "closes": "19:00"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.1",
        "reviewCount": "11",
        "bestRating": "5"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Services RS Multi-Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Petit bricolage" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Nettoyage intérieur et extérieur" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Entretien d'espaces verts" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Enlèvement d'encombrants" } }
        ]
      },
      "sameAs": ["https://www.allovoisins.com/p/rsmultiservices-12"],
      "vatID": "FR-91119540200019",
      "taxID": "91119540200019"
    }
    </script>

    <!-- JSON-LD : Person (founder) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Raymond Spire",
      "jobTitle": "Artisan multi-services",
      "worksFor": { "@type": "Organization", "name": "RS Multi-Services" },
      "telephone": "+33619696812",
      "email": "raymond.spire31@gmail.com",
      "address": { "@type": "PostalAddress", "addressLocality": "Pechbonnieu", "postalCode": "31140", "addressCountry": "FR" },
      "url": "https://rsmultiservices.fr/about"
    }
    </script>

    <!-- JSON-LD : BreadcrumbList -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://rsmultiservices.fr/" }
      ]
    }
    </script>

    <!-- JSON-LD : FAQPage -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Quelle est la zone d'intervention de RS Multi-Services ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nous intervenons à Toulouse et dans toute son agglomération, dans un rayon de 50 km autour de Pechbonnieu (31140) : L'Union, Castelmaurou, Launaguet, Aucamville, Fenouillet, Saint-Jean, Balma, Quint-Fonsegrives et toutes les communes du nord toulousain." }
        },
        {
          "@type": "Question",
          "name": "Quels sont vos horaires de disponibilité ?",
          "acceptedAnswer": { "@type": "Answer", "text": "RS Multi-Services est disponible 7 jours sur 7, du lundi au dimanche, de 8h00 à 19h00 — weekends et jours fériés inclus." }
        },
        {
          "@type": "Question",
          "name": "Le devis est-il payant ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Non, le devis est entièrement gratuit et sans engagement. Nous établissons une estimation claire après avoir évalué le travail à effectuer, par téléphone, par message ou sur place." }
        },
        {
          "@type": "Question",
          "name": "Comment sont calculés les tarifs ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Nos tarifs dépendent de la nature du travail (bricolage, jardinage, nettoyage, débarras), du temps nécessaire et du matériel à fournir. Aucun frais de déplacement caché dans la zone des 50 km autour de Toulouse." }
        },
        {
          "@type": "Question",
          "name": "RS Multi-Services est-il une entreprise déclarée ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Oui. RS Multi-Services est une entreprise individuelle (auto-entrepreneur) immatriculée sous le SIRET 911 195 402 00019, fondée en novembre 2023 par Raymond Spire. Identité, téléphone et entreprise sont vérifiés sur Allovoisins." }
        },
        {
          "@type": "Question",
          "name": "Combien de temps pour obtenir une réponse ?",
          "acceptedAnswer": { "@type": "Answer", "text": "En moyenne, nous répondons à vos messages en moins de 7 minutes. Pour une intervention rapide, le téléphone (06 19 69 68 12) reste le moyen le plus efficace." }
        }
      ]
    }
    </script>
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="hero">
    <img class="hero-bg" src="https://images.unsplash.com/photo-1416879595882-3373a0480b5b?auto=format&fit=crop&w=1920&q=80" onerror="this.onerror=null;this.src='https://picsum.photos/seed/rs-hero-multiservice/1920/1080';" alt="" aria-hidden="true">
    <div class="container">
      <div class="hero-mini-rating"><span class="stars-mini">★★★★★</span> 4,1/5 · 11 avis sur Allovoisins</div>
      <h1>
        Votre quotidien,
        <span class="accent-line">notre métier multi-services</span>
      </h1>
      <p class="hero-lead">Bricolage, entretien d'espaces verts, nettoyage intérieur/extérieur et enlèvement d'encombrants — une solution unique pour particuliers et professionnels à Toulouse et 50 km autour. Réactivité, soin du détail et juste prix.</p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary btn-lg"><i class="fa-solid fa-paper-plane"></i> Demander un devis</a>
        <a href="tel:+33619696812" class="btn btn-ghost btn-lg"><i class="fa-solid fa-phone"></i> 06 19 69 68 12</a>
      </div>
      <div class="hero-trust">
        <div class="item"><i class="fa-solid fa-clock"></i> 7j/7 · 8h-19h</div>
        <div class="item"><i class="fa-solid fa-bolt"></i> Réponse sous 7 min</div>
        <div class="item"><i class="fa-solid fa-shield-halved"></i> SIRET 911 195 402 00019</div>
        <div class="item"><i class="fa-solid fa-handshake"></i> 329+ missions</div>
      </div>
    </div>
  </section>

  <!-- ============== SERVICES PRINCIPAUX ============== -->
  <section id="services">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Nos services</span>
        <h2 class="section-title mx-auto">Solutions complètes pour la maison, le jardin et les pros</h2>
        <p class="section-lead mx-auto">Un seul interlocuteur pour entretenir, réparer, nettoyer ou débarrasser. RS Multi-Services intervient chez les particuliers, les bureaux et sur chantier.</p>
      </div>

      <div class="services-grid">
        <article class="service-card reveal">
          <div class="service-icon"><i class="fa-solid fa-screwdriver-wrench"></i></div>
          <h3>Petit bricolage</h3>
          <p>Réparations, fixations, montages, ajustements : tous les petits travaux que vous remettez à plus tard.</p>
          <ul>
            <li>Pose et fixation d'étagères</li>
            <li>Montage de meubles</li>
            <li>Rebouchage de trous & retouches</li>
            <li>Petits travaux d'électricité</li>
          </ul>
        </article>

        <article class="service-card reveal">
          <div class="service-icon"><i class="fa-solid fa-leaf"></i></div>
          <h3>Entretien espace vert</h3>
          <p>Tonte, taille, débroussaillage, motoculteur, élagage : votre extérieur retrouve toute sa beauté.</p>
          <ul>
            <li>Tonte de pelouse & débroussaillage</li>
            <li>Taille de haies et arbustes</li>
            <li>Élagage et coupe d'arbres</li>
            <li>Aménagement de terrain</li>
          </ul>
        </article>

        <article class="service-card reveal">
          <div class="service-icon"><i class="fa-solid fa-spray-can-sparkles"></i></div>
          <h3>Nettoyage intérieur / extérieur</h3>
          <p>Pour la maison, le bureau ou le chantier — un nettoyage soigné, du sol au plafond.</p>
          <ul>
            <li>Nettoyage maison & bureau</li>
            <li>Nettoyage de fin de chantier</li>
            <li>Terrasses, façades, allées</li>
            <li>Vitrerie et surfaces</li>
          </ul>
        </article>

        <article class="service-card reveal">
          <div class="service-icon"><i class="fa-solid fa-truck-arrow-right"></i></div>
          <h3>Enlèvement d'encombrants</h3>
          <p>Vide-maison, débarras de cave, locaux pro : on évacue, vous récupérez votre espace.</p>
          <ul>
            <li>Vide maison complet</li>
            <li>Débarras cave / grenier</li>
            <li>Locaux professionnels</li>
            <li>Aide au déménagement</li>
          </ul>
        </article>
      </div>

      <div class="text-center reveal" style="margin-top:36px;">
        <a href="/services" class="btn btn-outline">Voir tous les services <i class="fa-solid fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ============== MARQUEE TICKER ============== -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-item"><i class="fa-solid fa-screwdriver-wrench"></i> Bricolage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-leaf"></i> Tonte & débroussaillage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-tree"></i> Élagage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-spray-can-sparkles"></i> Nettoyage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-truck-arrow-right"></i> Vide-maison <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-boxes-stacked"></i> Déménagement <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-scissors"></i> Taille de haies <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-bolt"></i> Petite électricité <span class="sep">◆</span></span>
      <!-- duplicate for seamless loop -->
      <span class="marquee-item"><i class="fa-solid fa-screwdriver-wrench"></i> Bricolage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-leaf"></i> Tonte & débroussaillage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-tree"></i> Élagage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-spray-can-sparkles"></i> Nettoyage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-truck-arrow-right"></i> Vide-maison <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-boxes-stacked"></i> Déménagement <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-scissors"></i> Taille de haies <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-bolt"></i> Petite électricité <span class="sep">◆</span></span>
    </div>
  </div>

  <!-- ============== PROCESS ============== -->
  <section class="deco-bg">
    <span class="deco-blob b1"></span>
    <span class="deco-blob b2"></span>
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Comment ça marche</span>
        <h2 class="section-title mx-auto">Quatre étapes simples, du premier message au sourire final</h2>
        <p class="section-lead mx-auto">Pas de jargon, pas de paperasse inutile. On va droit au but pour vous faire gagner du temps.</p>
      </div>
      <div class="process-grid">
        <div class="process-step reveal"><div class="step-num">1</div><h4>Vous nous contactez</h4><p>Par téléphone, message ou formulaire — décrivez votre besoin en quelques mots.</p></div>
        <div class="process-step reveal"><div class="step-num">2</div><h4>Devis gratuit</h4><p>Réponse en moins de 7 min en moyenne avec une estimation claire et sans engagement.</p></div>
        <div class="process-step reveal"><div class="step-num">3</div><h4>Intervention</h4><p>On arrive à l'heure, avec le bon matériel, et on réalise le travail proprement.</p></div>
        <div class="process-step reveal"><div class="step-num">4</div><h4>Satisfaction</h4><p>Validation finale ensemble, espace nettoyé, paiement simple. Tout simplement.</p></div>
      </div>
    </div>
  </section>

  <!-- ============== ENGAGEMENT ============== -->
  <section class="engagement">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Avec nous</span>
        <h2 class="section-title mx-auto">Notre engagement vers l'excellence</h2>
        <p class="section-lead mx-auto">Une approche simple : être là quand vous en avez besoin, faire le travail bien fait, et tenir parole.</p>
      </div>
      <div class="stats-grid" style="margin-bottom:40px;">
        <div class="stat-card reveal">
          <div class="stat-icon"><i class="fa-solid fa-handshake"></i></div>
          <div class="num"><span data-count="329">0</span><span class="unit">+</span></div>
          <div class="label">Missions réalisées</div>
        </div>
        <div class="stat-card reveal">
          <div class="stat-icon"><i class="fa-solid fa-star"></i></div>
          <div class="num"><span data-count="4.1" data-decimals="1">0</span><span class="unit">/5</span></div>
          <div class="label">Note Allovoisins (11 avis)</div>
        </div>
        <div class="stat-card reveal">
          <div class="stat-icon"><i class="fa-solid fa-bolt"></i></div>
          <div class="num"><span data-count="7">0</span><span class="unit"> min</span></div>
          <div class="label">Délai de réponse moyen</div>
        </div>
        <div class="stat-card reveal">
          <div class="stat-icon"><i class="fa-solid fa-route"></i></div>
          <div class="num"><span data-count="50">0</span><span class="unit"> km</span></div>
          <div class="label">Rayon autour de Toulouse</div>
        </div>
      </div>

      <div class="engagement-grid">
        <div class="feature-card reveal">
          <div class="feature-icon"><i class="fa-solid fa-clock-rotate-left"></i></div>
          <h4>Réactivité</h4>
          <p>Réponse à vos messages en moins de 7 minutes en moyenne et intervention rapide.</p>
        </div>
        <div class="feature-card reveal accent-blue">
          <div class="feature-icon"><i class="fa-solid fa-calendar-check"></i></div>
          <h4>7j/7 · 8h-19h</h4>
          <p>Disponible toute la semaine, weekends inclus, pour s'adapter à votre planning.</p>
        </div>
        <div class="feature-card reveal accent-orange">
          <div class="feature-icon"><i class="fa-solid fa-route"></i></div>
          <h4>50 km autour</h4>
          <p>Toulouse et toute son agglomération : nous venons à vous sans frais cachés.</p>
        </div>
        <div class="feature-card reveal">
          <div class="feature-icon"><i class="fa-solid fa-file-invoice"></i></div>
          <h4>Devis gratuit</h4>
          <p>Tarif calculé en fonction du travail à effectuer. Pas de surprise, pas d'engagement.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== RÉALISATIONS ============== -->
  <section>
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Nos réalisations</span>
        <h2 class="section-title mx-auto">Quelques chantiers récents</h2>
        <p class="section-lead mx-auto">Aperçu de quelques interventions réalisées chez nos clients particuliers et professionnels.</p>
      </div>
      <div class="projects-grid">
        <a class="project-card reveal" data-lightbox="https://images.unsplash.com/photo-1581244277943-fe4a9c777189?auto=format&fit=crop&w=1400&q=80">
          <img src="https://images.unsplash.com/photo-1581244277943-fe4a9c777189?auto=format&fit=crop&w=900&q=80" alt="Tranchée creusée à outils manuels - réalisation RS Multi-Services">
          <div class="overlay"><div><span>Terrassement</span><h4>Tranchée 30 m à outils manuels</h4></div></div>
        </a>
        <a class="project-card reveal" data-lightbox="https://images.unsplash.com/photo-1518780664697-55e3ad937233?auto=format&fit=crop&w=1400&q=80">
          <img src="https://images.unsplash.com/photo-1518780664697-55e3ad937233?auto=format&fit=crop&w=900&q=80" alt="Cabane de jardin avec toit refait par RS Multi-Services">
          <div class="overlay"><div><span>Bricolage</span><h4>Réfection toit de cabane</h4></div></div>
        </a>
        <a class="project-card reveal" data-lightbox="https://images.unsplash.com/photo-1564507592333-c60657eea523?auto=format&fit=crop&w=1400&q=80">
          <img src="https://images.unsplash.com/photo-1564507592333-c60657eea523?auto=format&fit=crop&w=900&q=80" alt="Pose d'un brise-vue dans un jardin">
          <div class="overlay"><div><span>Aménagement</span><h4>Pose d'un brise-vue</h4></div></div>
        </a>
        <a class="project-card reveal" data-lightbox="https://images.unsplash.com/photo-1599629954294-14df9ec8bc03?auto=format&fit=crop&w=1400&q=80">
          <img src="https://images.unsplash.com/photo-1599629954294-14df9ec8bc03?auto=format&fit=crop&w=900&q=80" alt="Tonte de pelouse réalisée par RS Multi-Services">
          <div class="overlay"><div><span>Espaces verts</span><h4>Tonte & débroussaillage</h4></div></div>
        </a>
      </div>
      <div class="text-center reveal" style="margin-top:36px;">
        <a href="/projects" class="btn btn-outline">Voir toutes les réalisations <i class="fa-solid fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ============== TÉMOIGNAGES ============== -->
  <section style="background: var(--rs-cream);">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Témoignages</span>
        <h2 class="section-title mx-auto">Ce que nos clients disent</h2>
        <p class="section-lead mx-auto">Avis réels publiés sur Allovoisins — note moyenne 4,1/5 sur 11 avis.</p>
      </div>

      <div class="testimonial-track" id="testimonial-track">
        <article class="testimonial-card">
          <div class="stars">★★★★★</div>
          <blockquote>« Très professionnel, sérieux, je le recommande vivement. Excellent rapport qualité/prix. »</blockquote>
          <div class="testimonial-author">
            <div class="avatar">CD</div>
            <div class="meta"><strong>Charlie D.</strong><span>Taille de haies — avr. 2026</span></div>
          </div>
        </article>
        <article class="testimonial-card">
          <div class="stars">★★★★★</div>
          <blockquote>« La personne a été réactive et a bien travaillé, le résultat est propre. Excellent rapport qualité/prix. »</blockquote>
          <div class="testimonial-author">
            <div class="avatar">AB</div>
            <div class="meta"><strong>Aziz B.</strong><span>Tonte & débroussaillage — avr. 2026</span></div>
          </div>
        </article>
        <article class="testimonial-card">
          <div class="stars">★★★★★</div>
          <blockquote>« Super sympathique, plein de bons conseils pour le jardin, on voit qu'il sait ce qu'il fait et surtout il fait un excellent travail ! »</blockquote>
          <div class="testimonial-author">
            <div class="avatar">NB</div>
            <div class="meta"><strong>Nono B.</strong><span>Tonte & débroussaillage — avr. 2026</span></div>
          </div>
        </article>
        <article class="testimonial-card">
          <div class="stars">★★★★★</div>
          <blockquote>« Rien à dire, au top. Pas de bla-bla pour rien : simple et efficace. »</blockquote>
