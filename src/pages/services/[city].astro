---
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const cities = [
    { slug: 'toulouse', name: 'Toulouse' },
    { slug: 'colomiers', name: 'Colomiers' },
    { slug: 'tournefeuille', name: 'Tournefeuille' },
    { slug: 'blagnac', name: 'Blagnac' },
    { slug: 'muret', name: 'Muret' },
    { slug: 'plaisance-du-touch', name: 'Plaisance-du-Touch' },
    { slug: 'cugnaux', name: 'Cugnaux' },
    { slug: 'balma', name: 'Balma' },
    { slug: 'l-union', name: 'L\'Union' },
    { slug: 'saint-orens-de-gameville', name: 'Saint-Orens-de-Gameville' },
    { slug: 'ramonville-saint-agne', name: 'Ramonville-Saint-Agne' },
    { slug: 'castanet-tolosan', name: 'Castanet-Tolosan' },
    { slug: 'portet-sur-garonne', name: 'Portet-sur-Garonne' },
    { slug: 'revel', name: 'Revel' },
    { slug: 'villefranche-de-lauragais', name: 'Villefranche-de-Lauragais' },
    { slug: 'grenade', name: 'Grenade' },
    { slug: 'saint-jory', name: 'Saint-Jory' },
    { slug: 'pechbonnieu', name: 'Pechbonnieu' },
    { slug: 'aucamville', name: 'Aucamville' },
    { slug: 'castelginest', name: 'Castelginest' },
    { slug: 'fenouillet', name: 'Fenouillet' },
    { slug: 'saint-alban', name: 'Saint-Alban' },
    { slug: 'launaguet', name: 'Launaguet' },
    { slug: 'gratentour', name: 'Gratentour' },
    { slug: 'bruguieres', name: 'Bruguières' },
    { slug: 'saint-jean', name: 'Saint-Jean' },
    { slug: 'quint-fonsegrives', name: 'Quint-Fonsegrives' }
  ];

  return cities.map(city => ({
    params: { city: city.slug },
    props: { name: city.name }
  }));
}

const { name } = Astro.props;
const { city } = Astro.params;
---

<BaseLayout
  title={`Artisan Multi-Services à ${name} — Bricolage, Jardinage, Nettoyage | RS Multi-Services`}
  description={`RS Multi-Services intervient à ${name} et ses alentours pour tous vos besoins en petit bricolage, entretien d'espaces verts, nettoyage et débarras. Devis gratuit sous 7 min.`}
  canonical={`https://rsmultiservices.fr/services/${city}`}
>
  <Fragment slot="head">
    <!-- SEO local dynamique pour les IA -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": `RS Multi-Services ${name}`,
      "description": `Services de bricolage, jardinage et nettoyage à domicile à ${name} et environs.`,
      "url": `https://rsmultiservices.fr/services/${city}`,
      "telephone": "+33619696812",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": name,
        "addressRegion": "Occitanie",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 43.6047, // Coordonnées génériques Toulouse, l'IA comprendra la zone
        "longitude": 1.4442
      },
      "areaServed": {
        "@type": "City",
        "name": name
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": `Services à ${name}`,
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bricolage" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Jardinage" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Nettoyage" } }
        ]
      }
    })} />
  </Fragment>

  <section class="page-header" style="background-image: url('/assets/bg-multiservice.png');">
    <div class="container">
      <h1>Nos services multi-services à {name}</h1>
      <p>Artisan de proximité à votre service pour le bricolage, le jardin et le nettoyage à {name}.</p>
      <nav class="breadcrumbs" aria-label="Fil d'ariane">
        <a href="/">Accueil</a>
        <i class="fa-solid fa-chevron-right" style="font-size:.7rem"></i>
        <a href="/services">Services</a>
        <i class="fa-solid fa-chevron-right" style="font-size:.7rem"></i>
        <span>{name}</span>
      </nav>
    </div>
  </section>

  <section>
    <div class="container two-cols">
      <div class="reveal">
        <span class="section-eyebrow">Expert de proximité</span>
        <h2>Votre artisan de confiance à {name}</h2>
        <p>Vous habitez à <strong>{name}</strong> ou dans les environs et vous cherchez un artisan polyvalent pour vos petits travaux ? RS Multi-Services se déplace chez vous pour simplifier votre quotidien.</p>
        <p>Que ce soit pour une étagère à poser, une pelouse à tondre ou un local à vider, nous intervenons avec réactivité et professionnalisme à {name} (31).</p>
        <div style="margin-top: 24px;">
           <a href="/contact" class="btn btn-primary"><i class="fa-solid fa-paper-plane"></i> Demander mon devis à {name}</a>
        </div>
      </div>
      <div class="reveal">
        <img src="/assets/service-bricolage.png" alt={`Artisan multi-services intervenant à ${name}`}>
      </div>
    </div>
  </section>

  <section id="services" style="background: var(--rs-gradient-soft);">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Prestations</span>
        <h2 class="section-title mx-auto">Ce que nous faisons pour vous à {name}</h2>
      </div>
      <div class="engagement-grid">
        <div class="feature-card reveal">
          <div class="feature-icon"><i class="fa-solid fa-screwdriver-wrench"></i></div>
          <h4>Bricolage</h4>
          <p>Montage de meubles, fixations, petite électricité et plomberie à {name}.</p>
        </div>
        <div class="feature-card reveal accent-blue">
          <div class="feature-icon"><i class="fa-solid fa-leaf"></i></div>
          <h4>Jardinage</h4>
          <p>Tonte, taille de haies et entretien d'espaces verts pour les jardins de {name}.</p>
        </div>
        <div class="feature-card reveal accent-orange">
          <div class="feature-icon"><i class="fa-solid fa-spray-can-sparkles"></i></div>
          <h4>Nettoyage</h4>
          <p>Mise au propre de votre intérieur, locaux pro ou fin de chantier à {name}.</p>
        </div>
        <div class="feature-card reveal">
          <div class="feature-icon"><i class="fa-solid fa-truck-arrow-right"></i></div>
          <h4>Débarras</h4>
          <p>Évacuation d'encombrants et aide au déménagement partout à {name}.</p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="cta-banner reveal">
        <div>
          <h2>Besoin d'un coup de main à {name} ?</h2>
          <p>Devis gratuit en 7 minutes. Disponible 7j/7 pour toutes vos urgences et projets à {name}.</p>
        </div>
        <div class="actions">
          <a href="/contact" class="btn btn-primary btn-lg"><i class="fa-solid fa-envelope"></i> Devis gratuit</a>
          <a href="tel:+33619696812" class="btn btn-ghost btn-lg"><i class="fa-solid fa-phone"></i> 06 19 69 68 12</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
