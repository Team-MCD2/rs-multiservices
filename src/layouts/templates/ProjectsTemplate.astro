---
import BaseLayout from '../BaseLayout.astro';
import { cities } from '../../utils/cities';

interface Props {
  city: string;
  cityName: string;
}

const { city, cityName } = Astro.props;
---

<BaseLayout
  title={`Nos réalisations à ${cityName} — Chantiers RS Multi-Services`}
  description={`Découvrez nos chantiers réalisés à ${cityName} et environs : bricolage, jardinage, nettoyage. Photos avant/après et réalisations concrètes.`}
  canonical={`https://rsmultiservices.fr/${city}/realisations`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `https://rsmultiservices.fr/${city}/` },
        { "@type": "ListItem", "position": 2, "name": "Réalisations", "item": `https://rsmultiservices.fr/${city}/realisations` }
      ]
    })} />
  </Fragment>

  <section class="page-header" style="background-image: url('/assets/bg-multiservice.png');">
    <div class="container">
      <h1>Nos réalisations à {cityName}</h1>
      <p>Aperçu en images de nos interventions récentes chez nos clients à {cityName} et alentours.</p>
      <nav class="breadcrumbs" aria-label="Fil d'ariane">
        <a href={`/${city}/`}>Accueil</a>
        <i class="fa-solid fa-chevron-right" style="font-size:.7rem"></i>
        <span>Réalisations</span>
      </nav>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="projects-grid">
        <a class="project-card reveal" data-lightbox="/assets/project-tranchee.png">
          <img src="/assets/project-tranchee.png" alt={`Tranchée à ${cityName}`}>
          <div class="overlay"><div><span>Terrassement</span><h4>Tranchée 30 m</h4></div></div>
        </a>
        <a class="project-card reveal" data-lightbox="/assets/project-cabane.png">
          <img src="/assets/project-cabane.png" alt={`Cabane à ${cityName}`}>
          <div class="overlay"><div><span>Bricolage</span><h4>Réfection toit</h4></div></div>
        </a>
        <a class="project-card reveal" data-lightbox="/assets/project-brise-vue.png">
          <img src="/assets/project-brise-vue.png" alt={`Brise-vue à ${cityName}`}>
          <div class="overlay"><div><span>Aménagement</span><h4>Pose brise-vue</h4></div></div>
        </a>
        <a class="project-card reveal" data-lightbox="/assets/project-tonte.png">
          <img src="/assets/project-tonte.png" alt={`Tonte pelouse à ${cityName}`}>
          <div class="overlay"><div><span>Espaces verts</span><h4>Tonte & débroussaillage</h4></div></div>
        </a>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="cta-banner reveal">
        <div><h2>Votre projet à {cityName} ?</h2><p>Parlons-en dès aujourd'hui.</p></div>
        <div class="actions">
          <a href={`/${city}/contact`} class="btn btn-primary btn-lg"><i class="fa-solid fa-envelope"></i> Devis gratuit</a>
          <a href="tel:+33619696812" class="btn btn-ghost btn-lg"><i class="fa-solid fa-phone"></i> 06 19 69 68 12</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
