---
import BaseLayout from '../BaseLayout.astro';

interface Props {
  cityName?: string;
  citySlug?: string;
}

const { cityName = "{displayCity}", citySlug = "" } = Astro.props;
const displayCity = cityName;
const canonicalUrl = citySlug ? `{canonicalUrl}${citySlug}/services` : "{canonicalUrl}services";
---

<BaseLayout
  title={`Nos services — Bricolage, Jardinage, Nettoyage, Débarras | RS Multi-Services ${displayCity}`}
  description={`Découvrez tous les services RS Multi-Services à ${displayCity} : petit bricolage, tonte, taille, élagage, nettoyage maison/bureau/chantier, vide-maison, débarras. Devis gratuit 7j/7.`}
  canonical={canonicalUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "{canonicalUrl}" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "{canonicalUrl}services" }
      ]
    }
    </script>
  </Fragment>

  <section class="page-header" style="background-image: url('/assets/bg-garden.png');">
    <div class="container">
      <h1>Nos services multi-services à {displayCity}</h1>
      <p>Une seule équipe, tous vos besoins : bricolage, espaces verts, nettoyage et débarras.</p>
      <nav class="breadcrumbs" aria-label="Fil d'ariane"><a href="/">Accueil</a><i class="fa-solid fa-chevron-right" style="font-size:.7rem"></i><span>Services</span></nav>
    </div>
  </section>

  <!-- Bloc 1 : Bricolage -->
  <section id="bricolage">
    <div class="container">
      <div class="service-block reveal">
        <div>
          <span class="label">Service 01</span>
          <h2>Petit bricolage</h2>
          <p>Tous ces petits travaux qui s'accumulent à la maison ? On s'en occupe en une seule visite. Réparations, fixations, montages, ajustements : nous intervenons rapidement avec le bon matériel.</p>
          <ul>
            <li>Pose d'étagères, tringles, tableaux</li>
            <li>Montage de meubles en kit</li>
            <li>Rebouchage de trous & retouches peinture</li>
            <li>Petits travaux d'électricité (interrupteur, prise…)</li>
            <li>Fixation et perçage</li>
            <li>Pose et entretien serrurerie</li>
          </ul>
          <a href="/contact?service=bricolage" class="btn btn-primary"><i class="fa-solid fa-wrench"></i> Demander un devis</a>
        </div>
        <img src="/assets/service-bricolage.png" alt="Petit bricolage et réparations à domicile">
      </div>
    </div>
  </section>

  <!-- Bloc 2 : Espaces verts -->
  <section id="jardinage" style="background: var(--rs-gradient-soft);">
    <div class="container">
      <div class="service-block reverse reveal">
        <div>
          <span class="label">Service 02</span>
          <h2>Entretien d'espaces verts</h2>
          <p>De la simple tonte à l'aménagement complet de votre jardin : équipé en motoculteur, débroussailleuse et outils d'élagage, nous redonnons vie à vos extérieurs.</p>
          <ul>
            <li>Tonte de pelouse</li>
            <li>Débroussaillage</li>
            <li>Coupe d'herbe</li>
            <li>Taille de haies & arbustes</li>
            <li>Élagage et coupe d'arbres</li>
            <li>Passage de motoculteur</li>
            <li>Aménagement de terrain</li>
            <li>Pose de clôture / grillage / brise-vue</li>
          </ul>
          <a href="/contact?service=jardinage" class="btn btn-primary"><i class="fa-solid fa-leaf"></i> Demander un devis</a>
        </div>
        <img src="/assets/service-jardinage.png" alt="Entretien d'espace vert à {displayCity}">
      </div>
    </div>
  </section>

  <!-- Bloc 3 : Nettoyage -->
  <section id="nettoyage">
    <div class="container">
      <div class="service-block reveal">
        <div>
          <span class="label">Service 03</span>
          <h2>Nettoyage intérieur / extérieur</h2>
          <p>Maison, bureau, locaux professionnels ou fin de chantier : nous nettoyons en profondeur, avec produits adaptés et soin du détail.</p>
          <ul>
            <li>Nettoyage maison & appartement</li>
            <li>Bureaux & espaces de travail</li>
            <li>Nettoyage de fin de chantier</li>
            <li>Vitres et surfaces vitrées</li>
            <li>Terrasses, allées, façades</li>
            <li>Locaux professionnels</li>
          </ul>
          <a href="/contact?service=nettoyage" class="btn btn-primary"><i class="fa-solid fa-spray-can-sparkles"></i> Demander un devis</a>
        </div>
        <img src="/assets/service-nettoyage.png" alt="Nettoyage professionnel et résidentiel">
      </div>
    </div>
  </section>

  <!-- Bloc 4 : Encombrants -->
  <section id="encombrants" style="background: var(--rs-gradient-soft);">
    <div class="container">
      <div class="service-block reverse reveal">
        <div>
          <span class="label">Service 04</span>
          <h2>Enlèvement d'encombrants & déménagement</h2>
          <p>Vide-maison, débarras de cave ou de grenier, locaux professionnels à libérer ? On charge, on évacue et on laisse l'espace propre. Possibilité d'aide au déménagement.</p>
          <ul>
            <li>Vide maison complet</li>
            <li>Débarras cave, grenier, garage</li>
            <li>Locaux professionnels</li>
            <li>Évacuation gravats & déchets verts</li>
            <li>Aide au déménagement</li>
            <li>Tri & recyclage</li>
          </ul>
          <a href="/contact?service=encombrants" class="btn btn-primary"><i class="fa-solid fa-truck-arrow-right"></i> Demander un devis</a>
        </div>
        <img src="/assets/service-encombrants.png" alt="Enlèvement d'encombrants et débarras">
      </div>
    </div>
  </section>

  <!-- Tarifs -->
  <section>
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Tarifs</span>
        <h2 class="section-title mx-auto">Un devis personnalisé, gratuit et sans engagement</h2>
        <p class="section-lead mx-auto">Nos tarifs sont calculés en fonction du travail à effectuer. Décrivez-nous votre besoin par téléphone ou via le formulaire — nous revenons vers vous très vite avec une estimation claire.</p>
      </div>
      <div class="text-center reveal">
        <a href="/contact" class="btn btn-primary btn-lg"><i class="fa-solid fa-paper-plane"></i> Obtenir mon devis gratuit</a>
        <a href="tel:+33619696812" class="btn btn-outline btn-lg" style="margin-left:8px"><i class="fa-solid fa-phone"></i> Appeler maintenant</a>
      </div>
    </div>
  </section>
</BaseLayout>
