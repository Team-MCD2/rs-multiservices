---
import BaseLayout from '../BaseLayout.astro';
import { cities } from '../../utils/cities';

interface Props {
  city: string;
  cityName: string;
}

const { city, cityName } = Astro.props;
---

<BaseLayout
  title={`Services Bricolage, Jardinage, Nettoyage à ${cityName} — RS Multi-Services`}
  description={`Découvrez tous les services RS Multi-Services à ${cityName} : petit bricolage, tonte, taille, élagage, nettoyage, débarras. Devis gratuit à ${cityName}.`}
  canonical={`https://rsmultiservices.fr/${city}/services`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `https://rsmultiservices.fr/${city}/` },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": `https://rsmultiservices.fr/${city}/services` }
      ]
    })} />
  </Fragment>

  <section class="page-header" style="background-image: url('/assets/bg-garden.png');">
    <div class="container">
      <h1>Nos services multi-services à {cityName}</h1>
      <p>Une seule équipe pour tous vos besoins à {cityName} : bricolage, espaces verts, nettoyage et débarras.</p>
      <nav class="breadcrumbs" aria-label="Fil d'ariane">
        <a href={`/${city}/`}>Accueil</a>
        <i class="fa-solid fa-chevron-right" style="font-size:.7rem"></i>
        <span>Services</span>
      </nav>
    </div>
  </section>

  <!-- Bloc 1 : Bricolage -->
  <section id="bricolage">
    <div class="container">
      <div class="service-block reveal">
        <div>
          <span class="label">Service 01</span>
          <h2>Petit bricolage à {cityName}</h2>
          <p>Tous ces petits travaux qui s'accumulent à {cityName} ? On s'en occupe en une seule visite. Réparations, fixations, montages, ajustements.</p>
          <ul>
            <li>Pose d'étagères, tringles, tableaux</li>
            <li>Montage de meubles en kit</li>
            <li>Rebouchage de trous & retouches peinture</li>
            <li>Petits travaux d'électricité</li>
          </ul>
          <a href={`/${city}/contact?service=bricolage`} class="btn btn-primary"><i class="fa-solid fa-wrench"></i> Devis bricolage</a>
        </div>
        <img src="/assets/service-bricolage.png" alt={`Petit bricolage à ${cityName}`}>
      </div>
    </div>
  </section>

  <!-- Bloc 2 : Espaces verts -->
  <section id="jardinage" style="background: var(--rs-gradient-soft);">
    <div class="container">
      <div class="service-block reverse reveal">
        <div>
          <span class="label">Service 02</span>
          <h2>Entretien d'espaces verts à {cityName}</h2>
          <p>De la simple tonte à l'aménagement complet de votre jardin à {cityName} : équipé pour tout type de terrain.</p>
          <ul>
            <li>Tonte de pelouse & débroussaillage</li>
            <li>Taille de haies & arbustes</li>
            <li>Élagage et coupe d'arbres</li>
            <li>Pose de clôture / brise-vue</li>
          </ul>
          <a href={`/${city}/contact?service=jardinage`} class="btn btn-primary"><i class="fa-solid fa-leaf"></i> Devis jardin</a>
        </div>
        <img src="/assets/service-jardinage.png" alt={`Entretien jardin à ${cityName}`}>
      </div>
    </div>
  </section>

  <!-- Bloc 3 : Nettoyage -->
  <section id="nettoyage">
    <div class="container">
      <div class="service-block reveal">
        <div>
          <span class="label">Service 03</span>
          <h2>Nettoyage à {cityName}</h2>
          <p>Maison, bureau, locaux professionnels ou fin de chantier à {cityName} : nous nettoyons en profondeur.</p>
          <ul>
            <li>Nettoyage maison & appartement</li>
            <li>Bureaux & espaces de travail</li>
            <li>Nettoyage de fin de chantier</li>
            <li>Terrasses, allées, façades</li>
          </ul>
          <a href={`/${city}/contact?service=nettoyage`} class="btn btn-primary"><i class="fa-solid fa-spray-can-sparkles"></i> Devis nettoyage</a>
        </div>
        <img src="/assets/service-nettoyage.png" alt={`Nettoyage à ${cityName}`}>
      </div>
    </div>
  </section>

  <!-- Tarifs -->
  <section>
    <div class="container">
      <div class="cta-banner reveal">
        <div><h2>Besoin d'un devis à {cityName} ?</h2><p>Réponse en moins de 7 minutes.</p></div>
        <div class="actions">
          <a href={`/${city}/contact`} class="btn btn-primary btn-lg"><i class="fa-solid fa-paper-plane"></i> Devis gratuit</a>
          <a href="tel:+33619696812" class="btn btn-ghost btn-lg"><i class="fa-solid fa-phone"></i> 06 19 69 68 12</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
