---
import BaseLayout from '../BaseLayout.astro';
import { cities } from '../../utils/cities';

interface Props {
  city: string;
  cityName: string;
}

const { city, cityName } = Astro.props;
---

<BaseLayout
  title={`RS Multi-Services ${cityName} — Bricolage, Jardinage, Nettoyage, Débarras 7j/7`}
  description={`RS Multi-Services à ${cityName} et 50 km autour : petit bricolage, entretien d'espaces verts, nettoyage intérieur/extérieur, enlèvement d'encombrants. Devis gratuit, disponible 7j/7.`}
  canonical={`https://rsmultiservices.fr/${city}`}
  hasHero={true}
>
  <Fragment slot="head">
    <style>
      /* 1) Le header flotte par-dessus le hero (pas dans le flux) */
      body.has-hero .site-header {
        position: fixed !important;
        top: 0; left: 0; right: 0;
        z-index: 100;
      }

      /* 2) État TRANSPARENT au top de la page */
      body.has-hero .site-header:not(.is-scrolled) {
        background: transparent !important;
        backdrop-filter: none !important;
        -webkit-backdrop-filter: none !important;
        border-bottom: 1px solid transparent !important;
        box-shadow: none !important;
      }
      body.has-hero .site-header:not(.is-scrolled) .nav { background: transparent !important; }
      body.has-hero .site-header:not(.is-scrolled) .brand-text strong,
      body.has-hero .site-header:not(.is-scrolled) .nav-menu > li > a,
      body.has-hero .site-header:not(.is-scrolled) .nav-tel,
      body.has-hero .site-header:not(.is-scrolled) .nav-toggle { color:#fff !important; }
      body.has-hero .site-header:not(.is-scrolled) .brand-text span { color: rgba(255,255,255,0.85) !important; }
      body.has-hero .site-header:not(.is-scrolled) .brand img { filter: drop-shadow(0 2px 10px rgba(0,0,0,0.55)); }
    </style>

    <!-- JSON-LD : LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HomeAndConstructionBusiness",
      "name": `RS Multi-Services ${cityName}`,
      "alternateName": "R&S Multi-Services",
      "description": `Bricolage, entretien d'espaces verts, nettoyage intérieur/extérieur et enlèvement d'encombrants à ${cityName} et 50 km autour.`,
      "image": "https://rsmultiservices.fr/assets/og-image.png",
      "url": `https://rsmultiservices.fr/${city}`,
      "telephone": "+33619696812",
      "email": "raymond.spire31@gmail.com",
      "priceRange": "€€",
      "founder": { "@type": "Person", "name": "Raymond Spire" },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": cityName,
        "addressRegion": "Occitanie",
        "addressCountry": "FR"
      },
      "geo": { "@type": "GeoCoordinates", "latitude": 43.6047, "longitude": 1.4442 },
      "areaServed": cities.map(c => ({ "@type": "City", "name": c.name })),
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
        "opens": "08:00",
        "closes": "19:00"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.1",
        "reviewCount": "11",
        "bestRating": "5"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": `Services RS Multi-Services ${cityName}`,
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Petit bricolage" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Nettoyage intérieur et extérieur" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Entretien d'espaces verts" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Enlèvement d'encombrants" } }
        ]
      },
      "sameAs": ["https://www.allovoisins.com/p/rsmultiservices-12"]
    })} />
  </Fragment>

  <!-- ============== HERO ============== -->
  <section class="hero">
    <img class="hero-bg" src="/assets/bg-hero.png" onerror="this.onerror=null;this.src='https://picsum.photos/seed/rs-hero-multiservice/1920/1080';" alt="" aria-hidden="true">
    <div class="container">
      <div class="hero-mini-rating"><span class="stars-mini">★★★★★</span> 4,1/5 · 11 avis sur Allovoisins</div>
      <h1>
        Votre quotidien à {cityName},
        <span class="accent-line">notre métier multi-services</span>
      </h1>
      <p class="hero-lead">Bricolage, entretien d'espaces verts, nettoyage intérieur/extérieur et enlèvement d'encombrants — une solution unique pour particuliers et professionnels à {cityName} et 50 km autour. Réactivité, soin du détail et juste prix.</p>
      <div class="hero-actions">
        <a href={`/${city}/contact`} class="btn btn-primary btn-lg"><i class="fa-solid fa-paper-plane"></i> Demander un devis</a>
        <a href="tel:+33619696812" class="btn btn-ghost btn-lg"><i class="fa-solid fa-phone"></i> 06 19 69 68 12</a>
      </div>
      <div class="hero-trust">
        <div class="item"><i class="fa-solid fa-clock"></i> 7j/7 · 8h-19h</div>
        <div class="item"><i class="fa-solid fa-bolt"></i> Réponse sous 7 min</div>
        <div class="item"><i class="fa-solid fa-shield-halved"></i> SIRET 911 195 402 00019</div>
        <div class="item"><i class="fa-solid fa-handshake"></i> 329+ missions</div>
      </div>
    </div>
  </section>

  <!-- ============== SERVICES PRINCIPAUX ============== -->
  <section id="services">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Nos services</span>
        <h2 class="section-title mx-auto">Solutions complètes à {cityName}</h2>
        <p class="section-lead mx-auto">Un seul interlocuteur pour entretenir, réparer, nettoyer ou débarrasser à {cityName}. RS Multi-Services intervient chez les particuliers, les bureaux et sur chantier.</p>
      </div>

      <div class="services-grid">
        <article class="service-card reveal">
          <div class="service-icon"><i class="fa-solid fa-screwdriver-wrench"></i></div>
          <h3>Petit bricolage</h3>
          <p>Réparations, fixations, montages, ajustements à {cityName} : tous les petits travaux que vous remettez à plus tard.</p>
          <ul>
            <li>Pose et fixation d'étagères</li>
            <li>Montage de meubles</li>
            <li>Rebouchage de trous & retouches</li>
            <li>Petits travaux d'électricité</li>
          </ul>
        </article>

        <article class="service-card reveal">
          <div class="service-icon"><i class="fa-solid fa-leaf"></i></div>
          <h3>Entretien espace vert</h3>
          <p>Tonte, taille, débroussaillage à {cityName} : votre extérieur retrouve toute sa beauté.</p>
          <ul>
            <li>Tonte de pelouse & débroussaillage</li>
            <li>Taille de haies et arbustes</li>
            <li>Élagage et coupe d'arbres</li>
            <li>Aménagement de terrain</li>
          </ul>
        </article>

        <article class="service-card reveal">
          <div class="service-icon"><i class="fa-solid fa-spray-can-sparkles"></i></div>
          <h3>Nettoyage</h3>
          <p>Pour la maison, le bureau ou le chantier à {cityName} — un nettoyage soigné, du sol au plafond.</p>
          <ul>
            <li>Nettoyage maison & bureau</li>
            <li>Nettoyage de fin de chantier</li>
            <li>Terrasses, façades, allées</li>
            <li>Vitrerie et surfaces</li>
          </ul>
        </article>

        <article class="service-card reveal">
          <div class="service-icon"><i class="fa-solid fa-truck-arrow-right"></i></div>
          <h3>Encombrants</h3>
          <p>Vide-maison, débarras de cave à {cityName} : on évacue, vous récupérez votre espace.</p>
          <ul>
            <li>Vide maison complet</li>
            <li>Débarras cave / grenier</li>
            <li>Locaux professionnels</li>
            <li>Aide au déménagement</li>
          </ul>
        </article>
      </div>

      <div class="text-center reveal" style="margin-top:36px;">
        <a href={`/${city}/services`} class="btn btn-outline">Voir tous les services <i class="fa-solid fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ============== MARQUEE TICKER ============== -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-item"><i class="fa-solid fa-screwdriver-wrench"></i> Bricolage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-leaf"></i> Tonte & débroussaillage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-tree"></i> Élagage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-spray-can-sparkles"></i> Nettoyage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-truck-arrow-right"></i> Vide-maison <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-boxes-stacked"></i> Déménagement <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-scissors"></i> Taille de haies <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-bolt"></i> Petite électricité <span class="sep">◆</span></span>
      <!-- duplicate for seamless loop -->
      <span class="marquee-item"><i class="fa-solid fa-screwdriver-wrench"></i> Bricolage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-leaf"></i> Tonte & débroussaillage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-tree"></i> Élagage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-spray-can-sparkles"></i> Nettoyage <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-truck-arrow-right"></i> Vide-maison <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-boxes-stacked"></i> Déménagement <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-scissors"></i> Taille de haies <span class="sep">◆</span></span>
      <span class="marquee-item"><i class="fa-solid fa-bolt"></i> Petite électricité <span class="sep">◆</span></span>
    </div>
  </div>

  <!-- ============== AREAS ============== -->
  <section style="background: var(--rs-cream);">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Localités</span>
        <h2 class="section-title mx-auto">Où intervenons-nous ?</h2>
        <p class="section-lead mx-auto">RS Multi-Services se déplace à {cityName} et dans toutes les communes environnantes.</p>
      </div>
      <div class="areas-grid reveal">
        {cities.map(c => (
          <a href={`/${c.slug}/`}>{c.name}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============== PROCESS ============== -->
  <section class="deco-bg">
    <span class="deco-blob b1"></span>
    <span class="deco-blob b2"></span>
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Comment ça marche</span>
        <h2 class="section-title mx-auto">Quatre étapes simples</h2>
        <p class="section-lead mx-auto">Pas de jargon, pas de paperasse inutile à {cityName}.</p>
      </div>
      <div class="process-grid">
        <div class="process-step reveal"><div class="step-num">1</div><h4>Vous nous contactez</h4><p>Par téléphone, message ou formulaire — décrivez votre besoin en quelques mots.</p></div>
        <div class="process-step reveal"><div class="step-num">2</div><h4>Devis gratuit</h4><p>Réponse en moins de 7 min en moyenne avec une estimation claire et sans engagement.</p></div>
        <div class="process-step reveal"><div class="step-num">3</div><h4>Intervention</h4><p>On arrive à l'heure à {cityName}, avec le bon matériel.</p></div>
        <div class="process-step reveal"><div class="step-num">4</div><h4>Satisfaction</h4><p>Validation finale ensemble, espace nettoyé, paiement simple.</p></div>
      </div>
    </div>
  </section>

  <!-- ============== ENGAGEMENT ============== -->
  <section class="engagement">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Avec nous</span>
        <h2 class="section-title mx-auto">Notre engagement vers l'excellence</h2>
        <p class="section-lead mx-auto">Une approche simple : être là quand vous en avez besoin à {cityName}.</p>
      </div>
      <div class="stats-grid" style="margin-bottom:40px;">
        <div class="stat-card reveal">
          <div class="stat-icon"><i class="fa-solid fa-handshake"></i></div>
          <div class="num"><span data-count="329">0</span><span class="unit">+</span></div>
          <div class="label">Missions réalisées</div>
        </div>
        <div class="stat-card reveal">
          <div class="stat-icon"><i class="fa-solid fa-star"></i></div>
          <div class="num"><span data-count="4.1" data-decimals="1">0</span><span class="unit">/5</span></div>
          <div class="label">Note Allovoisins (11 avis)</div>
        </div>
        <div class="stat-card reveal">
          <div class="stat-icon"><i class="fa-solid fa-bolt"></i></div>
          <div class="num"><span data-count="7">0</span><span class="unit"> min</span></div>
          <div class="label">Délai de réponse moyen</div>
        </div>
        <div class="stat-card reveal">
          <div class="stat-icon"><i class="fa-solid fa-route"></i></div>
          <div class="num"><span data-count="50">0</span><span class="unit"> km</span></div>
          <div class="label">Rayon autour de {cityName}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============== RÉALISATIONS ============== -->
  <section>
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Nos réalisations</span>
        <h2 class="section-title mx-auto">Quelques chantiers récents</h2>
        <p class="section-lead mx-auto">Aperçu de quelques interventions réalisées près de {cityName}.</p>
      </div>
      <div class="projects-grid">
        <a class="project-card reveal" data-lightbox="/assets/project-tranchee.png">
          <img src="/assets/project-tranchee.png" alt="Tranchée creusée à outils manuels - réalisation RS Multi-Services">
          <div class="overlay"><div><span>Terrassement</span><h4>Tranchée 30 m</h4></div></div>
        </a>
        <a class="project-card reveal" data-lightbox="/assets/project-cabane.png">
          <img src="/assets/project-cabane.png" alt="Cabane de jardin avec toit refait par RS Multi-Services">
          <div class="overlay"><div><span>Bricolage</span><h4>Réfection toit</h4></div></div>
        </a>
        <a class="project-card reveal" data-lightbox="/assets/project-brise-vue.png">
          <img src="/assets/project-brise-vue.png" alt="Pose d'un brise-vue dans un jardin">
          <div class="overlay"><div><span>Aménagement</span><h4>Pose d'un brise-vue</h4></div></div>
        </a>
        <a class="project-card reveal" data-lightbox="/assets/project-tonte.png">
          <img src="/assets/project-tonte.png" alt="Tonte de pelouse réalisée par RS Multi-Services">
          <div class="overlay"><div><span>Espaces verts</span><h4>Tonte & débroussaillage</h4></div></div>
        </a>
      </div>
      <div class="text-center reveal" style="margin-top:36px;">
        <a href={`/${city}/realisations`} class="btn btn-outline">Voir toutes les réalisations <i class="fa-solid fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ============== TÉMOIGNAGES ============== -->
  <section style="background: var(--rs-cream);">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Témoignages</span>
        <h2 class="section-title mx-auto">Ce que nos clients disent</h2>
        <p class="section-lead mx-auto">Avis réels publiés sur Allovoisins — note moyenne 4,1/5.</p>
      </div>

      <div class="testimonial-track" id="testimonial-track">
        <article class="testimonial-card">
          <div class="stars">★★★★★</div>
          <blockquote>« Très professionnel, sérieux, je le recommande vivement. »</blockquote>
          <div class="testimonial-author">
            <div class="avatar">CD</div>
            <div class="meta"><strong>Charlie D.</strong><span>Taille de haies</span></div>
          </div>
        </article>
        <article class="testimonial-card">
          <div class="stars">★★★★★</div>
          <blockquote>« La personne a été réactive et a bien travaillé, le résultat est propre. »</blockquote>
          <div class="testimonial-author">
            <div class="avatar">AB</div>
            <div class="meta"><strong>Aziz B.</strong><span>Tonte & débroussaillage</span></div>
          </div>
        </article>
      </div>

      <div class="testimonial-controls">
        <button data-testimonial-prev aria-label="Témoignage précédent"><i class="fa-solid fa-arrow-left"></i></button>
        <button data-testimonial-next aria-label="Témoignage suivant"><i class="fa-solid fa-arrow-right"></i></button>
      </div>
    </div>
  </section>

  <!-- ============== CTA ============== -->
  <section>
    <div class="container">
      <div class="cta-banner reveal">
        <div>
          <h2>Prêt à passer à l'action à {cityName} ?</h2>
          <p>Décrivez-nous votre projet — nous revenons vers vous en quelques minutes.</p>
        </div>
        <div class="actions">
          <a href={`/${city}/contact`} class="btn btn-primary btn-lg"><i class="fa-solid fa-paper-plane"></i> Devis gratuit</a>
          <a href="tel:+33619696812" class="btn btn-ghost btn-lg"><i class="fa-solid fa-phone"></i> 06 19 69 68 12</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
