---
import BaseLayout from '../BaseLayout.astro';

interface Props {
  city: string;
  cityName: string;
}

const { city, cityName } = Astro.props;
---

<BaseLayout
  title={`Contact & Devis gratuit à ${cityName} — RS Multi-Services`}
  description={`Contactez RS Multi-Services à ${cityName} pour un devis gratuit : bricolage, jardinage, nettoyage, débarras. Disponible 7j/7 à ${cityName}.`}
  canonical={`https://rsmultiservices.fr/${city}/contact`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `https://rsmultiservices.fr/${city}/` },
        { "@type": "ListItem", "position": 2, "name": "Contact", "item": `https://rsmultiservices.fr/${city}/contact` }
      ]
    })} />
  </Fragment>

  <section class="page-header" style="background-image: url('/assets/bg-multiservice.png');">
    <div class="container">
      <h1>Contact & devis gratuit à {cityName}</h1>
      <p>Une question, un projet à {cityName} ? Nous vous répondons en moins de 7 minutes.</p>
      <nav class="breadcrumbs" aria-label="Fil d'ariane">
        <a href={`/${city}/`}>Accueil</a>
        <i class="fa-solid fa-chevron-right" style="font-size:.7rem"></i>
        <span>Contact</span>
      </nav>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="contact-grid">
        <div class="reveal">
          <h2>Votre projet à {cityName}</h2>
          <p style="color:var(--rs-muted);">Indiquez la nature du service à {cityName} et vos disponibilités.</p>

          <form id="contact-form" novalidate>
            <div class="form-msg" role="alert"></div>
            <div class="form-grid">
              <div class="form-row">
                <label for="name">Nom complet *</label>
                <input id="name" name="name" type="text" required autocomplete="name" placeholder="Jean Dupont">
              </div>
              <div class="form-row">
                <label for="email">Email *</label>
                <input id="email" name="email" type="email" required autocomplete="email" placeholder="vous@exemple.fr">
              </div>
              <div class="form-row full">
                <label for="message">Décrivez votre besoin à {cityName} *</label>
                <textarea id="message" name="message" required placeholder={`Ex. : tonte à ${cityName}, montage de meubles…`}></textarea>
              </div>
              <div class="form-row full">
                <button type="submit" class="btn btn-primary btn-lg" style="width:100%; justify-content:center;">
                  <i class="fa-solid fa-paper-plane"></i> Envoyer ma demande
                </button>
              </div>
            </div>
          </form>
        </div>

        <aside class="contact-info reveal">
          <h3>Joignez-nous à {cityName}</h3>
          <ul>
            <li>
              <span class="icon"><i class="fa-solid fa-phone"></i></span>
              <div><strong>Téléphone</strong><a href="tel:+33619696812">06 19 69 68 12</a></div>
            </li>
            <li>
              <span class="icon"><i class="fa-solid fa-location-dot"></i></span>
              <div><strong>Zone d'intervention</strong><span>{cityName} et 50 km autour</span></div>
            </li>
          </ul>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
