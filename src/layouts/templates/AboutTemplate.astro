---
import BaseLayout from '../BaseLayout.astro';
import { cities } from '../../utils/cities';

interface Props {
  city: string;
  cityName: string;
}

const { city, cityName } = Astro.props;
---

<BaseLayout
  title={`À propos — RS Multi-Services ${cityName} | Raymond Spire, artisan multi-services`}
  description={`Découvrez RS Multi-Services, l'entreprise de Raymond Spire à ${cityName}. Bricolage, jardinage, nettoyage et débarras à ${cityName} et 50 km autour.`}
  canonical={`https://rsmultiservices.fr/${city}/about`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": `https://rsmultiservices.fr/${city}/` },
        { "@type": "ListItem", "position": 2, "name": "À propos", "item": `https://rsmultiservices.fr/${city}/about` }
      ]
    })} />
  </Fragment>

  <section class="page-header" style="background-image: url('/assets/bg-multiservice.png');">
    <div class="container">
      <h1>À propos de RS Multi-Services à {cityName}</h1>
      <p>Un artisan, une promesse : faire le travail bien, dans la bonne humeur, à {cityName}.</p>
      <nav class="breadcrumbs" aria-label="Fil d'ariane">
        <a href={`/${city}/`}>Accueil</a>
        <i class="fa-solid fa-chevron-right" style="font-size:.7rem"></i>
        <span>À propos</span>
      </nav>
    </div>
  </section>

  <section>
    <div class="container two-cols">
      <div class="reveal">
        <span class="section-eyebrow">Notre histoire</span>
        <h2>Savoir-faire au service des habitants de {cityName}</h2>
        <p>Fondée en novembre 2023 par <strong>Raymond Spire</strong>, RS Multi-Services accompagne les habitants de {cityName} et son agglomération sur tous les petits et grands tracas du quotidien.</p>
        <p>Un robinet à changer, un jardin à remettre en état à {cityName}, une cave à vider ? Une solution, un seul interlocuteur.</p>
        <a href={`/${city}/contact`} class="btn btn-primary"><i class="fa-solid fa-paper-plane"></i> Discutons de votre projet</a>
      </div>
      <div class="reveal">
        <img src="/assets/service-bricolage.png" alt={`Artisan multi-services intervenant à ${cityName}`}>
      </div>
    </div>
  </section>

  <section class="engagement">
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Nos valeurs</span>
        <h2 class="section-title mx-auto">Ce qui guide nos interventions à {cityName}</h2>
      </div>
      <div class="engagement-grid">
        <div class="feature-card reveal"><div class="feature-icon"><i class="fa-solid fa-handshake"></i></div><h4>Confiance</h4><p>Devis clair, parole tenue à {cityName}.</p></div>
        <div class="feature-card reveal accent-blue"><div class="feature-icon"><i class="fa-solid fa-bolt"></i></div><h4>Réactivité</h4><p>Réponse en moins de 7 minutes à {cityName}.</p></div>
        <div class="feature-card reveal accent-orange"><div class="feature-icon"><i class="fa-solid fa-tools"></i></div><h4>Polyvalence</h4><p>Bricolage, jardinage, nettoyage à {cityName}.</p></div>
        <div class="feature-card reveal"><div class="feature-icon"><i class="fa-solid fa-seedling"></i></div><h4>Soin</h4><p>Chaque chantier à {cityName} est rendu propre.</p></div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="text-center reveal">
        <span class="section-eyebrow">Zone d'intervention</span>
        <h2 class="section-title mx-auto">Où intervenons-nous ?</h2>
        <p class="section-lead mx-auto">Nous nous déplaçons gratuitement à {cityName} et dans toute l'agglomération.</p>
      </div>
      <div class="text-center reveal">
        <div class="areas" style="justify-content:center;">
          {cities.slice(0, 15).map(c => <span>{c.name}</span>)}
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <div class="cta-banner reveal">
        <div><h2>Une question à {cityName} ?</h2><p>Parlez-nous de votre besoin, on s'occupe du reste.</p></div>
        <div class="actions">
          <a href={`/${city}/contact`} class="btn btn-primary btn-lg"><i class="fa-solid fa-envelope"></i> Devis gratuit</a>
          <a href="tel:+33619696812" class="btn btn-ghost btn-lg"><i class="fa-solid fa-phone"></i> 06 19 69 68 12</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
